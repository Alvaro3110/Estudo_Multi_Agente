# [ .gitignore ]

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
.venv/
venv/
ENV/

# Environment Variables (CRITICAL)
.env
.env.*

# IDEs
.vscode/
.idea/

# Local logs and outputs
*.log
backend_logs.txt
frontend_logs.txt
backend/final_test_output.log
backend/final_test_sync*
backend/test_output.log

# Databases
*.db
backend/app/checkpoints.sqlite*
backend/mlflow.db

# Angular / Frontend
node_modules/
/dist/
.angular/
**/.angular/
frontend/.angular/
**/frontend/.angular/

# OS temporary files
.DS_Store
Thumbs.db
